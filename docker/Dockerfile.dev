FROM node:20-alpine
RUN npm install -g pnpm

WORKDIR /app

# Install dependencies layer (cached unless package.json changes)
COPY package.json ./
COPY prisma ./prisma

RUN pnpm install
RUN pnpm prisma generate

# Source is mounted as a volume at runtime — no COPY needed here

EXPOSE 4000

CMD ["pnpm", "start:dev"]
